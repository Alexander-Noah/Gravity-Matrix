APP_NAME=Gravity-Matrix Backend
API_PREFIX=/api/v1

# 数据库（默认 SQLite，无需安装任何服务）
DATABASE_URL=sqlite:///./data/gravity_matrix.db

# 想用 MySQL 的话，改成下面这行（需要先建库）
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/gravity_matrix

FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-a1ab29eab3284f278ffe17041b4e5a93
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=120

LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

MIN_CHAPTERS=3
MAX_CHAPTERS=30
MAX_CHAPTER_CHARS=20000
MAX_SCRIPT_YAML_CHARS=1000000

JWT_SECRET_KEY=your-production-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
