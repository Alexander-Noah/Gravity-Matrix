APP_NAME=Gravity-Matrix Backend
API_PREFIX=/api/v1

# Database
# Default SQLite works without installing a database service.
DATABASE_URL=sqlite:///./data/gravity_matrix.db

# Optional MySQL example. Create the database first before enabling it.
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/gravity_matrix

# Frontend origins allowed by CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# LLM provider. Recommended DeepSeek through OpenAI-compatible API.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=180

# Cost and speed controls.
LLM_MAX_CONCURRENCY=2
LLM_MAX_RETRIES=0
LLM_CHUNK_SIZE=3500
LLM_CHUNK_OVERLAP=0
LLM_ENABLE_CACHE=true

# Optional local fallback provider.
LLM_FALLBACK_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Novel import limits.
MIN_CHAPTERS=3
MAX_CHAPTERS=30
MAX_CHAPTER_CHARS=20000
MAX_SCRIPT_YAML_CHARS=1000000

# Auth. Change JWT_SECRET_KEY in production.
JWT_SECRET_KEY=your-production-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
