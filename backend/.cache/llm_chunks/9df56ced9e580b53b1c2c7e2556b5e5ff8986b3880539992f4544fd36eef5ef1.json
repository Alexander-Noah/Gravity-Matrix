  "dialogues": [
    {
      "speaker": "李玉春",
      "line": "妖物劫走税银的原因是什么？",
      "line_type": "dialogue",
      "emotion": "疑惑",
      "evidence": "李玉春道"
    },
    {
      "speaker": "陈府尹",
      "line": "妖类做事从不问心，为所欲为，追究原因，不过是自寻烦恼。",
      "line_type": "dialogue",
      "emotion": "无奈",
      "evidence": "陈府尹略一沉思"
    },
    {
      "speaker": "黄裙少女",
      "line": "人肉不是更好吃唔，你们稍等，我先吃完包子。",
      "line_type": "dialogue",
      "emotion": "随意",
      "evidence": "黄裙少女却有不同意见"
    },
    {
      "speaker": "黄裙少女",
      "line": "妖类做事无所顾忌，银子在它们眼里未必有活生生的人诱人。哪怕想要银子，偷窃或抢劫都比直接劫走税银要稳妥。",
      "line_type": "dialogue",
      "emotion": "分析",
      "evidence": "她继续刚才的话题"
    },
    {
      "speaker": "陈府尹",
      "line": "言之有理，不排除是受人指使。",
      "line_type": "dialogue",
      "emotion": "赞同",
      "evidence": "陈府尹点头"
    },
    {
      "speaker": "李玉春",
      "line": "那么谁会指使妖类窃取税银呢？理由是什么？为什么非得是这一批税银，非得是十五万两。",
      "line_type": "dialogue",
      "emotion": "追问",
      "evidence": "李玉春眯了眯眼"
    },
    {
      "speaker": "陈府尹",
      "line": "咱们可以这么想，幕后主使需要一笔巨款，但又不能闹出太大动静准确说，不能肆无忌惮的敛财。",
      "line_type": "dialogue",
      "emotion": "推测",
      "evidence": "陈府尹心里一动"
    },
    {
      "speaker": "黄裙少女",
      "line": "于是就盯上了税银？",
      "line_type": "dialogue",
      "emotion": "接话",
      "evidence": "黄裙少女抿了抿唇"
    }
